# ── DATABASE ──────────────────────────────────────────
# Option A: SQLite (zero setup, local dev)
DATABASE_URL=sqlite:///./hmf.db
# Option B: PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/hmf_db

# ── AUTH ──────────────────────────────────────────────
JWT_SECRET=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256

# ── FAISS (local vector DB — no API key needed) ───────
FAISS_DATA_DIR=data/faiss

# ── LOCAL LLM (Ollama — no API key needed) ────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_TAGS_URL=http://localhost:11434/api/tags
OLLAMA_MODEL=phi3:mini

# ── REDIS (rate limiting) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_RATE=1.0

# ── SHADOW GUARD (prompt injection defense) ──────────
SHADOW_GUARD_MODEL=phi3
SHADOW_GUARD_OLLAMA_URL=http://localhost:11434/api/generate
SHADOW_GUARD_FAIL_CLOSED=1
